{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./src",
    "types": ["jest", "node"],
    "paths": {
      "@/*": ["*"]
    },
    // "esModuleInterop": true,
  },
  "include": [
    "src/**/*.ts",
    "_test_/**/*.ts",
    "jest.config.ts",
    "jest.env.ts",
    "/types/express.d.ts"
  ],
  "exclude": [
    "dist", 
    "node_modules", 
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/_test_/**",
    "dist"
  ]
}
